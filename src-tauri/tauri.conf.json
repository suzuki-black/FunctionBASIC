{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FunctionBASIC",
  "version": "0.1.13",
  "identifier": "dev.functionbasic.editor",
  "build": {
    "frontendDist": "../editor",
    "beforeBuildCommand": "node build.mjs",
    "beforeDevCommand": "node build.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FunctionBASIC — Structured BASIC → MSX-BASIC",
        "width": 1100,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Structured BASIC → MSX-BASIC transpiler & editor",
    "longDescription": "Write modern, block-structured BASIC (functions, blocks, locals), transpile it to authentic MSX-BASIC, and run it in an embedded webMSX. Includes a decompiler for plain MSX-BASIC.",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
