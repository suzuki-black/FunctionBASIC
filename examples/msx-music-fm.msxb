' ============================================================
'  MSX-MUSIC (FM) demo via CALL MUSIC / CALL VOICE / PLAY #2.
'
'  To actually use the FM sound chip (YM2413) from BASIC:
'    CALL MUSIC(<drums>,0,<ch1>,<ch2>,...)  initialise FM
'    CALL VOICE(@n,@n,...)                   pick an FM instrument
'    PLAY #2, "...","..."                    play on device #2 (FM)
'  Plain PLAY (no #2) is the PSG; FM needs PLAY #2.
'  Inside the MML you can also switch instrument with @n.
'
'  REQUIRES MSX-MUSIC (FM). The transpiler output is correct (this plays
'  in MSXPen on an MSX2+ machine), but the embedded cross-origin WebMSX
'  player does not reliably sound FM here -- verify FM in MSXPen / openMSX
'  / real hardware. See TODO.md.
' ============================================================

' A short three-voice FM phrase on FM channels 1-3 (device #2).
' V15 = maximum MML volume on each FM channel (V0..V15).
FUNCTION FANFARE()
    PLAY #2, "V15 T130 O4 L8 CEGEC", "V15 T130 O3 L4 CG", "V15 T130 O5 L8 GCEGC"
END FUNCTION

' ---------------- MAIN ----------------
SCREEN 0
WIDTH 40
CLS
PRINT "MSX-MUSIC (FM) via PLAY #2"
PRINT

CALL MUSIC(0,0,1,1,1)      ' FM on, three melody channels
CALL VOICE(@7,@7,@7)       ' FM instrument @7 = Trumpet, on channels 1-3

FOR REPEAT = 1 TO 2
    PRINT "playing"; REPEAT
    FANFARE()
    ' let the phrase ring out (it plays in the background on the FM chip)
    FOR PAUSE = 1 TO 2500
    NEXT PAUSE
NEXT REPEAT

PRINT "done"
